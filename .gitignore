# Python
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
build/
dist/

# Test / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.coverage
htmlcov/

# uv virtualenvs (project-local layers)
.venv/
.venv-host/
# Backend model server venv (M3; numpy + web stack, OpenVINO via PYTHONPATH; host-coupled)
.venv-model/

# Local model weights (M3; downloaded via huggingface_hub, host+container-coupled, large)
models/

# Open WebUI (M4): app venv + runtime state (sqlite/uploads/cache; regenerable, recipe in webui/)
.venv-webui/
.webui-data/

# Failure-eval harness output (M3.4; host+model-coupled; headline numbers live in the roadmap)
bench/reports/
# Hardware-free hardening walkthrough output (M5.5e; regenerated by `python -m demo`)
demo/reports/

# Secrets / local env
.env
.env.*
!.env.example

# Service artifacts
.verifier-state/
# One-command launcher runtime (M7; per-service *.log + launch.pid; regenerable)
.launch-logs/
*.duckdb
*.duckdb.wal
*.log

# Serena runtime cache (project.yml is committed when present)
.serena/cache/

# Headroom tokensave code-graph state (regenerable: `tokensave init`/`sync`)
.tokensave/

# Claude Code machine-local (settings + private instructions)
.claude/settings.local.json
CLAUDE.local.md
# Headroom wrap live-session marker (ephemeral: pid/port/env key; removed on exit)
.claude/.headroom_wrap_marker.json

# OS
.DS_Store
Thumbs.db
