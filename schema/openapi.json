{
  "openapi": "3.1.0",
  "info": {
    "title": "verifier",
    "version": "0.2.0"
  },
  "paths": {
    "/health": {
      "get": {
        "operationId": "health",
        "summary": "Liveness and version probe",
        "responses": {
          "200": {
            "description": "The service is live; reports the running package version.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "version": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "status",
                    "version"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/verify-only": {
      "post": {
        "operationId": "verifyOnly",
        "summary": "Verify a VPlot spec and return a structured verdict",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VPlotSpec"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The verification verdict (verified, decoded-but-failed, or a decode failure) — never a chart.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Verdict"
                }
              }
            }
          },
          "413": {
            "description": "The request body exceeded the configured size cap.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "415": {
            "description": "The Content-Type was not application/json.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "429": {
            "description": "The process-local rate or active-job admission gate refused the work before model, verification, or render execution. Each service process owns an independent gate.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "500": {
            "description": "The verifier hit an internal operator-config, implementation, or archive fault.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          }
        }
      }
    },
    "/verify-and-render": {
      "post": {
        "operationId": "verifyAndRender",
        "summary": "Verify a VPlot spec and, only if verified, render the certified chart",
        "parameters": [
          {
            "name": "include_html",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VPlotSpec"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "A RenderVerdict with the certified chart on a passing verdict, or a plain Verdict on a failing one — each carrying its durably committed attempt_id, and never a chart on an unverified outcome.",
            "content": {
              "application/json": {
                "schema": {
                  "anyOf": [
                    {
                      "$ref": "#/components/schemas/RenderVerdict"
                    },
                    {
                      "$ref": "#/components/schemas/Verdict"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "The include_html query parameter was not a valid boolean.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "413": {
            "description": "The request body exceeded the configured size cap.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "415": {
            "description": "The Content-Type was not application/json.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "429": {
            "description": "The process-local rate or active-job admission gate refused the work before model, verification, or render execution. Each service process owns an independent gate.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "500": {
            "description": "The verifier hit an internal operator-config, implementation, or archive fault.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "507": {
            "description": "The signed attempt could not commit within the configured logical archive quota; the original endpoint outcome and any chart artifact were withheld.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          }
        }
      }
    },
    "/propose-spec": {
      "post": {
        "operationId": "proposeSpec",
        "summary": "Propose a VPlot spec with the local model, then verify and render it",
        "description": "Draft and verify a chart for a provisioned dataset. Given a natural-language chart request and a dataset name, the local model proposes a VPlot chart specification, which the verifier independently checks and — only if it passes every check — renders as a certified chart. Provide `user_request` (what to plot, for example \"monthly revenue by region\") and `dataset_name`, one of the provisioned CSV datasets (for example sales.csv or weather.csv). A verified proposal returns the certified chart to display; an unverifiable one returns the failing verdict instead.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProposeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "On a verified proposal, a [result, summary] array carrying the certified chart as an Open WebUI embed; on any other outcome, the bare result — the model's raw reply paired with the verify-and-render verdict (a plain verdict when unverified). Every admitted classified outcome carries its durably committed attempt_id.",
            "content": {
              "application/json": {
                "schema": {
                  "anyOf": [
                    {
                      "$ref": "#/components/schemas/ProposeResult"
                    },
                    {
                      "type": "array",
                      "prefixItems": [
                        {
                          "$ref": "#/components/schemas/ProposeResult"
                        },
                        {
                          "type": "string"
                        }
                      ],
                      "minItems": 2,
                      "maxItems": 2
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "The propose request body was malformed or failed validation.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "404": {
            "description": "No dataset with the requested name is provisioned.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "422": {
            "description": "The user request, bounded dataset context, assembled prompt, or exact backend-tokenized prompt exceeded proposer resource policy. No native model generation or verification occurred. UTF-8/file byte ceilings and the backend token ceiling are independent and inclusive.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "413": {
            "description": "The request body exceeded the configured size cap.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "415": {
            "description": "The Content-Type was not application/json.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "429": {
            "description": "The process-local rate or active-job admission gate refused the work before model, verification, or render execution. Each service process owns an independent gate.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "500": {
            "description": "The verifier hit an internal operator-config, implementation, or archive fault.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "507": {
            "description": "The signed attempt could not commit within the configured logical archive quota; the original endpoint outcome and any chart artifact were withheld.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "502": {
            "description": "The model backend replied, but not with a usable chat completion (any other non-success status, an oversized or malformed body, or no usable message content), or it proposed a specification for a different dataset than requested.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "503": {
            "description": "The model backend was unreachable or timed out.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          }
        }
      }
    },
    "/certificate/{plot_id}": {
      "get": {
        "operationId": "getCertificate",
        "summary": "Fetch a durable verified-plot certificate by plot_id",
        "parameters": [
          {
            "name": "plot_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The archive-authenticated canonical DSSE envelope bytes. Its plot_id is the SHA-256 digest of these exact bytes; the authenticated payload has the exact VCert v0.2 type. The archive key proves self-consistency, not signer trust or identity.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DSSEEnvelope"
                }
              }
            }
          },
          "404": {
            "description": "No stored artifact for that id, or a malformed id.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "500": {
            "description": "The provenance archive, stored relation, content address, or artifact authentication check failed. The cause is logged and withheld.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          }
        }
      }
    },
    "/spec/{spec_id}": {
      "get": {
        "operationId": "getSpec",
        "summary": "Fetch a durable verified spec's canonical bytes by spec_id",
        "parameters": [
          {
            "name": "spec_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The archive-validated canonical spec bytes. spec_id is canon.hash_spec of the decoded exact bytes.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VPlotSpec"
                }
              }
            }
          },
          "404": {
            "description": "No stored artifact for that id, or a malformed id.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "500": {
            "description": "The provenance archive, stored relation, content address, or artifact authentication check failed. The cause is logged and withheld.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          }
        }
      }
    },
    "/key/{keyid}": {
      "get": {
        "operationId": "getPublicKey",
        "summary": "Fetch an archived raw Ed25519 public key by exact keyid",
        "parameters": [
          {
            "name": "keyid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The exact raw 32-byte Ed25519 public key whose SHA-256 digest is keyid. Archive presence does not establish signer trust, identity, PKI status, or inclusion in the operator's independent trust policy.",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "404": {
            "description": "No stored artifact for that id, or a malformed id.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "500": {
            "description": "The provenance archive, stored relation, content address, or artifact authentication check failed. The cause is logged and withheld.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          }
        }
      }
    },
    "/chart/{plot_id}": {
      "get": {
        "operationId": "getChart",
        "summary": "Fetch a stored verified chart page by plot_id",
        "parameters": [
          {
            "name": "plot_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The stored offline chart HTML page (served text/html under a sandbox CSP).",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "description": "No stored artifact for that id, or a malformed id.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "VPlotSpec": {
        "title": "VPlotSpec",
        "type": "object",
        "properties": {
          "version": {
            "enum": [
              "vplot-0.1"
            ]
          },
          "dataset": {
            "$ref": "#/components/schemas/Dataset"
          },
          "transform": {
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "$ref": "#/components/schemas/Select"
                },
                {
                  "$ref": "#/components/schemas/Filter"
                },
                {
                  "$ref": "#/components/schemas/GroupBy"
                },
                {
                  "$ref": "#/components/schemas/Aggregate"
                },
                {
                  "$ref": "#/components/schemas/Sort"
                }
              ],
              "discriminator": {
                "propertyName": "op",
                "mapping": {
                  "select": "#/components/schemas/Select",
                  "filter": "#/components/schemas/Filter",
                  "group_by": "#/components/schemas/GroupBy",
                  "aggregate": "#/components/schemas/Aggregate",
                  "sort": "#/components/schemas/Sort"
                }
              }
            },
            "maxItems": 64
          },
          "mark": {
            "enum": [
              "bar",
              "line",
              "scatter"
            ]
          },
          "encoding": {
            "$ref": "#/components/schemas/Encoding"
          }
        },
        "required": [
          "version",
          "dataset",
          "transform",
          "mark",
          "encoding"
        ],
        "additionalProperties": false
      },
      "Dataset": {
        "title": "Dataset",
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 128,
            "pattern": "^(?!.*[\\r\\n])[A-Za-z0-9][A-Za-z0-9._-]*\\.csv$"
          },
          "hash": {
            "type": "string",
            "pattern": "^(?!.*[\\r\\n])sha256:[0-9a-f]{64}$"
          }
        },
        "required": [
          "name",
          "hash"
        ],
        "additionalProperties": false
      },
      "Select": {
        "title": "Select",
        "type": "object",
        "properties": {
          "op": {
            "enum": [
              "select"
            ]
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 64,
              "pattern": "^(?!.*[\\r\\n])[A-Za-z_][A-Za-z0-9_]*$"
            },
            "maxItems": 64,
            "minItems": 1
          }
        },
        "required": [
          "op",
          "fields"
        ],
        "additionalProperties": false
      },
      "Filter": {
        "title": "Filter",
        "type": "object",
        "properties": {
          "op": {
            "enum": [
              "filter"
            ]
          },
          "field": {
            "type": "string",
            "maxLength": 64,
            "pattern": "^(?!.*[\\r\\n])[A-Za-z_][A-Za-z0-9_]*$"
          },
          "cmp": {
            "enum": [
              "eq",
              "ge",
              "gt",
              "le",
              "lt",
              "ne"
            ]
          },
          "value": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": -9223372036854775808,
                "maximum": 9223372036854775807
              },
              {
                "type": "string",
                "maxLength": 128
              }
            ]
          }
        },
        "required": [
          "op",
          "field",
          "cmp",
          "value"
        ],
        "additionalProperties": false
      },
      "GroupBy": {
        "title": "GroupBy",
        "type": "object",
        "properties": {
          "op": {
            "enum": [
              "group_by"
            ]
          },
          "keys": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 64,
              "pattern": "^(?!.*[\\r\\n])[A-Za-z_][A-Za-z0-9_]*$"
            },
            "maxItems": 32,
            "minItems": 1
          }
        },
        "required": [
          "op",
          "keys"
        ],
        "additionalProperties": false
      },
      "Aggregate": {
        "title": "Aggregate",
        "type": "object",
        "properties": {
          "op": {
            "enum": [
              "aggregate"
            ]
          },
          "measures": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Measure"
            },
            "maxItems": 32,
            "minItems": 1
          }
        },
        "required": [
          "op",
          "measures"
        ],
        "additionalProperties": false
      },
      "Measure": {
        "title": "Measure",
        "type": "object",
        "properties": {
          "field": {
            "type": "string",
            "maxLength": 64,
            "pattern": "^(?!.*[\\r\\n])[A-Za-z_][A-Za-z0-9_]*$"
          },
          "fn": {
            "enum": [
              "count",
              "max",
              "mean",
              "min",
              "sum"
            ]
          },
          "as": {
            "type": "string",
            "maxLength": 64,
            "pattern": "^(?!.*[\\r\\n])[A-Za-z_][A-Za-z0-9_]*$"
          }
        },
        "required": [
          "field",
          "fn",
          "as"
        ],
        "additionalProperties": false
      },
      "Sort": {
        "title": "Sort",
        "type": "object",
        "properties": {
          "op": {
            "enum": [
              "sort"
            ]
          },
          "by": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SortKey"
            },
            "maxItems": 32,
            "minItems": 1
          }
        },
        "required": [
          "op",
          "by"
        ],
        "additionalProperties": false
      },
      "SortKey": {
        "title": "SortKey",
        "type": "object",
        "properties": {
          "field": {
            "type": "string",
            "maxLength": 64,
            "pattern": "^(?!.*[\\r\\n])[A-Za-z_][A-Za-z0-9_]*$"
          },
          "order": {
            "enum": [
              "ascending",
              "descending"
            ]
          }
        },
        "required": [
          "field",
          "order"
        ],
        "additionalProperties": false
      },
      "Encoding": {
        "title": "Encoding",
        "type": "object",
        "properties": {
          "x": {
            "$ref": "#/components/schemas/Channel"
          },
          "y": {
            "$ref": "#/components/schemas/Channel"
          },
          "color": {
            "anyOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Channel"
              }
            ],
            "default": null
          }
        },
        "required": [
          "x",
          "y"
        ],
        "additionalProperties": false
      },
      "Channel": {
        "title": "Channel",
        "type": "object",
        "properties": {
          "field": {
            "type": "string",
            "maxLength": 64,
            "pattern": "^(?!.*[\\r\\n])[A-Za-z_][A-Za-z0-9_]*$"
          },
          "type": {
            "enum": [
              "nominal",
              "ordinal",
              "quantitative",
              "temporal"
            ]
          }
        },
        "required": [
          "field",
          "type"
        ],
        "additionalProperties": false
      },
      "CertifiedCheck": {
        "title": "CertifiedCheck",
        "description": "One passing final result recorded with the method that established it.",
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "method": {
            "enum": [
              "construction",
              "deterministic_recompute",
              "resource_policy",
              "schema_validation",
              "z3_smt"
            ]
          },
          "status": {
            "enum": [
              "pass"
            ]
          }
        },
        "required": [
          "id",
          "method",
          "status"
        ],
        "additionalProperties": false
      },
      "CheckResult": {
        "title": "CheckResult",
        "description": "One blocking check's verdict and the method that established it.\n\n``method`` is closed and orthogonal to the dotted ``check`` family: evaluator failures named\n``schema.*`` still arise from deterministic recomputation, while ``spec.decode`` is schema\nvalidation. ``severity`` has one reserved value (advisory tiers are future work), so\n:attr:`VerificationReport.passed` consults ``status`` only.",
        "type": "object",
        "properties": {
          "check": {
            "type": "string"
          },
          "method": {
            "enum": [
              "construction",
              "deterministic_recompute",
              "resource_policy",
              "schema_validation",
              "z3_smt"
            ]
          },
          "status": {
            "enum": [
              "fail",
              "pass"
            ]
          },
          "severity": {
            "enum": [
              "blocking"
            ]
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "check",
          "method",
          "status",
          "severity",
          "message"
        ],
        "additionalProperties": false
      },
      "DisclosedFilter": {
        "title": "DisclosedFilter",
        "description": "One applied filter op, disclosed in the cert. `value` is model-controlled (arbitrary\ntext within FilterValue bounds) -> badge_html HTML-escapes it.",
        "type": "object",
        "properties": {
          "field": {
            "type": "string"
          },
          "cmp": {
            "type": "string"
          },
          "value": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "string"
              }
            ]
          }
        },
        "required": [
          "field",
          "cmp",
          "value"
        ],
        "additionalProperties": false
      },
      "DisclosedSort": {
        "title": "DisclosedSort",
        "description": "One applied sort key, disclosed in the cert (flattened across all sort ops in order).",
        "type": "object",
        "properties": {
          "field": {
            "type": "string"
          },
          "order": {
            "type": "string"
          }
        },
        "required": [
          "field",
          "order"
        ],
        "additionalProperties": false
      },
      "Problem": {
        "title": "Problem",
        "description": "RFC 9457 detail for a non-verification HTTP outcome.\n\n`type` defaults to the RFC's \"about:blank\" (omitted when default), `title` is the HTTP\nstatus reason phrase, `status` the code, `detail` the occurrence-specific message. Transport\nmisuse, work/prompt-policy refusal, upstream failure, and server faults use this shape.\n`attempt_id` is present only for an admitted, classified proposer fault whose signed occurrence\ncommitted successfully; pre-admission refusals and archive/internal faults omit it. A\nverification outcome never travels as a Problem — it is always a 200 Verdict.",
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "status": {
            "type": "integer"
          },
          "detail": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "default": "about:blank"
          },
          "attempt_id": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              {
                "type": "null"
              }
            ],
            "default": null
          }
        },
        "required": [
          "title",
          "status",
          "detail"
        ]
      },
      "ProposeRequest": {
        "title": "ProposeRequest",
        "description": "A /propose-spec request: the free-text ask plus the dataset to plot.\n\n`user_request` is admitted by its UTF-8 encoding (4 KiB by default, operator-configurable),\nnot JSON Schema's code-point `maxLength`; an over-policy request receives 422 before any model\ncall. The complete system + user message content has its own independent byte ceiling.\n\n`dataset_name` is the VPlot DatasetName — path-safe by construction (a traversal or a\nnon-`.csv` name cannot decode), so the untrusted caller cannot escape the trusted data\ndirectory through it. forbid_unknown_fields rejects any extra key at decode (a 400), like\nevery decoded request the service accepts.",
        "type": "object",
        "properties": {
          "user_request": {
            "type": "string"
          },
          "dataset_name": {
            "type": "string",
            "maxLength": 128,
            "pattern": "^(?!.*[\\r\\n])[A-Za-z0-9][A-Za-z0-9._-]*\\.csv$"
          }
        },
        "required": [
          "user_request",
          "dataset_name"
        ],
        "additionalProperties": false
      },
      "Tcb": {
        "title": "Tcb",
        "description": "The verifier/formal/display TCB stamped into VCert.\n\n``verifier_version`` identifies the package implementing the checks; ``z3_version`` the\nsolver behind ``z3_smt`` results. The remaining fields identify canonicalization and the\nnative display stack trusted to render verified data faithfully, NOT proven to do so. SVG is\nnot hashed and cross-machine byte identity is unclaimed. ``vendored_font_sha256`` identifies\nthe registered font asset, not proof that vl-convert selected it over a same-named system\nfont (``render_svg`` documents the same scope).",
        "type": "object",
        "properties": {
          "verifier_version": {
            "type": "string"
          },
          "z3_version": {
            "type": "string"
          },
          "canon_version": {
            "type": "string"
          },
          "python": {
            "type": "string"
          },
          "msgspec": {
            "type": "string"
          },
          "unidata": {
            "type": "string"
          },
          "vl_convert_python": {
            "type": "string"
          },
          "vl_version": {
            "type": "string"
          },
          "font_family": {
            "type": "string"
          },
          "vendored_font_sha256": {
            "type": "string"
          }
        },
        "required": [
          "verifier_version",
          "z3_version",
          "canon_version",
          "python",
          "msgspec",
          "unidata",
          "vl_convert_python",
          "vl_version",
          "font_family",
          "vendored_font_sha256"
        ],
        "additionalProperties": false
      },
      "VCert": {
        "title": "VCert",
        "description": "A VPlot v0.1 provenance certificate: five bound artifact hashes, method-bearing passing\nchecks, disclosed applied filters/sorts, and the verifier/formal/display TCB. Produced as a\ndeterministic payload by core render; the service signs its exact bytes into DSSE. Attestation\nverification decodes an external copy only after those bytes + their application type\nauthenticate under an independently trusted key. Durable replay follows in later M5 units.",
        "type": "object",
        "properties": {
          "version": {
            "enum": [
              "vcert-0.2"
            ]
          },
          "dataset_hash": {
            "type": "string"
          },
          "spec_hash": {
            "type": "string"
          },
          "plotted_table_hash": {
            "type": "string"
          },
          "manifest_hash": {
            "type": "string"
          },
          "vega_lite_hash": {
            "type": "string"
          },
          "checks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CertifiedCheck"
            }
          },
          "filters": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DisclosedFilter"
            }
          },
          "sorts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DisclosedSort"
            }
          },
          "tcb": {
            "$ref": "#/components/schemas/Tcb"
          }
        },
        "required": [
          "version",
          "dataset_hash",
          "spec_hash",
          "plotted_table_hash",
          "manifest_hash",
          "vega_lite_hash",
          "checks",
          "filters",
          "sorts",
          "tcb"
        ],
        "additionalProperties": false
      },
      "Verdict": {
        "title": "Verdict",
        "description": "The verification outcome (HTTP 200 regardless of the judgement).\n\n`layer` names the stage that produced it: \"decode\" when the raw body failed to decode\n(a lone synthetic spec.decode result), \"verify\" once decoding passed and the trusted\npipeline ran (dataset binding, recomputation, encoding/label, exact builder + SMT).\n`verified` is true only when every final result passed. `attempt_id` is present only after an\nartifact-producing route durably commits the signed occurrence; stateless `/verify-only`\nleaves it absent. The archived canonical verdict omits it too because the signed attempt\nenvelope - and therefore its content-derived id - does not exist until after those bytes are\nfixed.",
        "type": "object",
        "properties": {
          "verified": {
            "type": "boolean"
          },
          "layer": {
            "enum": [
              "decode",
              "verify"
            ]
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CheckResult"
            }
          },
          "attempt_id": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              {
                "type": "null"
              }
            ],
            "default": null
          }
        },
        "required": [
          "verified",
          "layer",
          "results"
        ]
      },
      "DSSEEnvelope": {
        "title": "DSSEEnvelope",
        "description": "A deterministic DSSE v1 envelope authenticating the exact base64-decoded VCert v0.2 payload bytes and application-specific payload type. Verify it against an independently pinned Ed25519 public key before parsing the payload.",
        "type": "object",
        "properties": {
          "payload": {
            "type": "string",
            "contentEncoding": "base64"
          },
          "payloadType": {
            "const": "application/vnd.figure-verification.vcert.v0.2+json"
          },
          "signatures": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DSSESignature"
            },
            "minItems": 1,
            "maxItems": 1
          }
        },
        "required": [
          "payload",
          "payloadType",
          "signatures"
        ]
      },
      "DSSESignature": {
        "title": "DSSESignature",
        "description": "The service's single Ed25519 signature. keyid is an unauthenticated lookup hint; trust comes only from an independently pinned public key.",
        "type": "object",
        "properties": {
          "keyid": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "sig": {
            "type": "string",
            "contentEncoding": "base64"
          }
        },
        "required": [
          "keyid",
          "sig"
        ]
      },
      "RenderVerdict": {
        "title": "RenderVerdict",
        "description": "A passing /verify-and-render outcome: the Verdict fields plus the render artifacts.\n\nOnly ever answered when `verified` is true — the field is typed `Literal[True]`, a STATIC\n(mypy) pin: constructing a RenderVerdict with `verified=False` is a type error, though\nmsgspec skips `Literal` checks at runtime (direct construction still builds one), so the\nruntime never-a-chart guarantee lives in the pipeline path (a failing verify-and-render\nreturns a plain Verdict, structurally without svg/html) plus the bad-corpus tests, not this\nfield alone. A DISTINCT struct rather than a Verdict subclass, so the handler's\nVerdict | RenderVerdict return stays a real union for mypy and the OpenAPI surface.\n`attempt_id` = SHA-256 hexdigest of the signed occurrence envelope committed atomically with\nthe complete plot bundle, before either in-memory LRU mutates.\n`plot_id` = SHA-256 hexdigest of the deterministic signed DSSE envelope bytes;\n`spec_id` = `spec_hash` minus its\n`sha256:` prefix (bare 64-hex). plot_id <-> spec_id is 1:1 only under stable trusted config;\nchanging the trusted manifest, verifier/formal TCB, emitted Vega bytes, or signing key keeps\nspec_id but changes plot_id, so several plot_ids can share a spec_id (store.py refcounts them).\nThe five `*_hash` fields are the authenticated VCert payload's verbatim\n`sha256:`-prefixed digests.\n`html` (omitted when absent via omit_defaults) carries the offline view only under\ninclude_html=true.",
        "type": "object",
        "properties": {
          "verified": {
            "const": true
          },
          "layer": {
            "enum": [
              "decode",
              "verify"
            ]
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CheckResult"
            }
          },
          "attempt_id": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "plot_id": {
            "type": "string"
          },
          "spec_id": {
            "type": "string"
          },
          "dataset_hash": {
            "type": "string"
          },
          "spec_hash": {
            "type": "string"
          },
          "plotted_table_hash": {
            "type": "string"
          },
          "manifest_hash": {
            "type": "string"
          },
          "vega_lite_hash": {
            "type": "string"
          },
          "svg": {
            "type": "string"
          },
          "html": {
            "type": "string"
          }
        },
        "required": [
          "verified",
          "layer",
          "results",
          "attempt_id",
          "plot_id",
          "spec_id",
          "dataset_hash",
          "spec_hash",
          "plotted_table_hash",
          "manifest_hash",
          "vega_lite_hash",
          "svg"
        ]
      },
      "ProposeResult": {
        "title": "ProposeResult",
        "description": "A /propose-spec outcome: the model's raw reply plus the verifier's verdict on it.\n\n`model_reply` is the backend's reply content verbatim (the proposed spec text, decoded to a\nstring but never re-encoded), carried so a caller sees exactly what the untrusted model\nproduced — including a malformed proposal that decoded to a failing verdict. `verdict` is the\nsame Verdict | RenderVerdict the verify-and-render pipeline returns: a RenderVerdict with the\ncertified chart when the proposal verified, a plain Verdict otherwise (never a chart on an\nunverified outcome). Response-only, so no forbid_unknown_fields; it rides Litestar's encoder\nlike RenderVerdict (the Literal[True] pin blocks decode/inspect, not encode), so openapi.py\nhand-derives its schema for the same reason.",
        "type": "object",
        "properties": {
          "model_reply": {
            "type": "string"
          },
          "verdict": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/RenderVerdict"
              },
              {
                "$ref": "#/components/schemas/Verdict"
              }
            ]
          }
        },
        "required": [
          "model_reply",
          "verdict"
        ]
      }
    }
  }
}
