{
  "version": "vplot-0.1",
  "dataset": {
    "name": "sales.csv",
    "hash": "sha256:76356bebaa43bc76ee98fd6a1f1aa29cd7f127408fd43de87adcb7ed5df0478f"
  },
  "transform": [
    {
      "op": "group_by",
      "keys": [
        "month"
      ]
    },
    {
      "op": "aggregate",
      "measures": [
        {
          "field": "orders",
          "fn": "sum",
          "as": "total_orders"
        }
      ]
    },
    {
      "op": "sort",
      "by": [
        {
          "field": "month",
          "order": "ascending"
        }
      ]
    }
  ],
  "mark": "line",
  "encoding": {
    "x": {
      "field": "month",
      "type": "ordinal"
    },
    "y": {
      "field": "total_orders",
      "type": "quantitative"
    }
  }
}
